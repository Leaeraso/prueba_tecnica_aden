<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- tree view -->
    <record id="university_enrollment_tree" model="ir.ui.view">
        <field name="name">university.enrollment.tree</field>
        <field name="model">university.enrollment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="student_id"/>
                <field name="career_id"/>
                <field name="study_plan_id"/>
                <field name="enrollment_date"/>
            </tree>
        </field>
    </record>

    <!-- form view -->
    <record id="university_enrollment_form" model="ir.ui.view">
        <field name="name">university.enrollment.form</field>
        <field name="model">university.enrollment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="student_id"/>
                        <field name="career_id"/>
                        <field name="study_plan_id"/>
                        <field name="enrollment_date"/>
                    </group>
                    <notebook>
                        <page string="Subjects">
                            <field name="enrollment_subject_classroom_ids">
                                <tree>
                                    <field name="subject_id" string="Subject"/>
                                    <field name="grade_id" string="Grade"/>
                                    <field name="classroom_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action view -->
    <record id="university_enrollment_action" model="ir.actions.act_window">
        <field name="name">Enrollments</field>
        <field name="res_model">university.enrollment</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- menu item -->
    <menuitem id="menu_university_enrollment" name="Enrollments" parent="menu_university_academic" action="university_enrollment_action" sequence="10" groups="university.group_university_academic"/>
</odoo>