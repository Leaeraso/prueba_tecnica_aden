<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- tree view -->
    <record id="university_career_tree" model="ir.ui.view">
        <field name="name">university.career.tree</field>
        <field name="model">university.career</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
                <field name="enrollment_count" string="Enrollments"/>
            </tree>
        </field>
    </record>

    <!-- form view -->
    <record id="university_career_form" model="ir.ui.view">
        <field name="name">university.career.form</field>
        <field name="model">university.career</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="grade_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action view -->
    <record id="university_career_action" model="ir.actions.act_window">
        <field name="name">Careers</field>
        <field name="res_model">university.career</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- menu item -->
    <menuitem id="menu_university_career" name="Careers" parent="menu_university_academic" action="university_career_action" sequence="10" />
</odoo>