<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- tree view -->
    <record id="university_grade_tree" model="ir.ui.view">
        <field name="name">university.grade.tree</field>
        <field name="model">university.grade</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- form view -->
    <record id="university_grade_form" model="ir.ui.view">
        <field name="name">university.grade.form</field>
        <field name="model">university.grade</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name"/>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action view -->
    <record id="university_grade_action" model="ir.actions.act_window">
        <field name="name">Grades</field>
        <field name="res_model">university.grade</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- menu item -->
    <menuitem id="menu_university_grade" name="Grades" parent="menu_university_config" action="university_grade_action" sequence="10" />
</odoo>