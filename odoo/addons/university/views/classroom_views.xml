<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- tree view -->
    <record id="university_classroom_tree" model="ir.ui.view">
        <field name="name">university.classroom.tree</field>
        <field name="model">university.classroom</field>
        <field name="arch" type="xml">
            <tree>
                <field name="classroom_number"/>
                <field name="capacity"/>
            </tree>
        </field>
    </record>

    <!-- form view -->
    <record id="university_classroom_form" model="ir.ui.view">
        <field name="name">university.classroom.form</field>
        <field name="model">university.classroom</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="classroom_number"/>
                        <field name="capacity"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action view -->
    <record id="university_classroom_action" model="ir.actions.act_window">
        <field name="name">Classrooms</field>
        <field name="res_model">university.classroom</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- sequence -->
    <record id="sequence_university_classroom" model="ir.sequence">
        <field name="name">Classroom Number</field>
        <field name="code">university.classroom</field>
        <field name="number_next">1</field>
        <field name="padding">1</field>
    </record>

    <!-- menu item -->
    <menuitem id="menu_university_classroom" name="Classrooms" parent="menu_university_config" action="university_classroom_action" sequence="10" groups="university.group_university_academic"/>
</odoo>