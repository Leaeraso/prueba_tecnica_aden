<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- tree view -->
    <record id="university_professor_tree" model="ir.ui.view">
        <field name="name">university.professor.tree</field>
        <field name="model">university.professor</field>
        <field name="arch" type="xml">
            <tree>
                <field name="professor_number"/>
                <field name="name"/>
                <field name="last_name"/>
                <field name="cuit"/>
                <field name="date_of_birth"/>
                <field name="email"/>
                <field name="phone"/>
            </tree>
        </field>
    </record>

    <!-- form view -->
    <record id="university_professor_form" model="ir.ui.view">
        <field name="name">university.professor.form</field>
        <field name="model">university.professor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="professor_number"/>
                        <field name="name"/>
                        <field name="last_name"/>
                        <field name="cuit"/>
                        <field name="date_of_birth"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="subject_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action view -->
    <record id="university_professor_action" model="ir.actions.act_window">
        <field name="name">Professors</field>
        <field name="res_model">university.professor</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- sequence -->
    <record id="sequence_university_professor" model="ir.sequence">
        <field name="name">Professor Number</field>
        <field name="code">university.professor</field>
        <field name="number_next">1000</field>
        <field name="padding">4</field>
    </record>

    <!-- menu item -->
    <menuitem id="menu_university_professor" name="Professors" parent="menu_university_people" action="university_professor_action" sequence="10" />
</odoo>