<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- tree view -->
    <record id="university_student_status_tree" model="ir.ui.view">
        <field name="name">university.student_status.tree</field>
        <field name="model">university.student_status</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- form view -->
    <record id="university_student_status_form" model="ir.ui.view">
        <field name="name">university.student_status.form</field>
        <field name="model">university.student_status</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name"/>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action view -->
    <record id="university_student_status_action" model="ir.actions.act_window">
        <field name="name">Student Status</field>
        <field name="res_model">university.student_status</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- menu item -->
    <menuitem id="menu_university_student_status" name="Student Status" parent="menu_university_config" action="university_student_status_action" sequence="10" />
</odoo>